{%  render 'partials/head.liquid' %}

{%  render 'partials/pijltje-terug.liquid' %}

<main class="formulier">
    <h1>Quickscan</h1>

    <svg class="sub-logo" width="735" height="523" viewBox="0 0 735 523" fill="none" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
        <rect x="101.215" width="663.313" height="340.579" transform="rotate(17.2885 101.215 0)" fill="url(#pattern0_10080_6)"/>
        <defs>
        <pattern id="pattern0_10080_6" patternContentUnits="objectBoundingBox" width="1" height="1">
        <use xlink:href="#image0_10080_6" transform="matrix(0.00330332 0 0 0.00643356 -0.140753 -0.527158)"/>
        </pattern>
        <image id="image0_10080_6" width="1024" height="315" preserveAspectRatio="none" xlink:href="data:image/png;base64,"/>
        </defs>
    </svg>

    <form class="formulier-quickscan">
        <label class="label-ctc">
            Adres:
            <input type="text">
        </label>

        <label class="label-ctc">
            Foto:
            <input type="file" class="foto">
        </label>

        <label class="label-ctc">
            Coördinaat:
            <textarea name="comment" maxlength="100"></textarea>
        </label>

        <label class="label-ctc">
            Status:
            <select>
                <option value="vrij">Vrij</option>
                <option value="bezet">Bezet</option>
                <option value="overtreding">Overtreding</option>
                <option value="bestaat niet">Bestaat niet</option>
            </select>
        </label>

        <label class="label-ctc">
            Verkeersbord:
            <input type="text">
        </label>
        
        <label class="label-ctc">
            Observaties:
            <textarea name="comment" maxlength="100"></textarea>
        </label>

        <label class="label-ctc">
            Geschiktheid monitoring:
            <select>
                <option value="neutraal">Neutraal</option>
                <option value="geschik">Geschikt</option>
                <option value="zeer geschikt">Zeer geschikt</option>
                <option value="ongeschikt">Ongeschikt</option>
            </select>
        </label>

        <label class="label-ctc">
            Geschiktheid smart zone:
            <select>
                <option value="neutraal">Neutraal</option>
                <option value="geschikt">Geschikt</option>
                <option value="zeer geschikt">Zeer geschikt</option>
                <option value="ongeschikt">Ongeschikt</option>
            </select>
        </label>

        <label class="label-ctc">
            Lengte(cm):
            <input type="text">
        </label>

        <input type="submit" value="Verzenden" class="verzend-knop">
    </form>
</main>